{
  "apiVersion": "claws.ab0t.com/v1",
  "kind": "Profile",
  "metadata": {
    "name": "solo-telegram-coder",
    "version": "1.1.0",
    "description": "One coding-focused agent on Telegram. Codex OAuth preferred, OPENAI_API_KEY fallback. Sandbox enabled, conservative DM policy.",
    "author": "ab0t",
    "license": "MIT",
    "tags": ["solo", "telegram", "coding"]
  },
  "runtime": {
    "name": "openclaw",
    "image": "openclaw:local"
  },
  "policy": {
    "loopbackOnly": true,
    "dmDefault": "pairing",
    "outboundDefault": "off"
  },
  "team": {
    "name": "default",
    "shared": true
  },
  "agents": [
    {
      "name": "agent-1",
      "sandbox": true,
      "tools": {
        "profile": "coding"
      },
      "config": {
        "agents.defaults.maxTokens": 4096
      },
      "auth": {
        "preferred": "codex",
        "fallbackApiKey": {
          "provider": "openai",
          "fromEnv": "OPENAI_API_KEY"
        }
      },
      "channels": [
        {
          "type": "telegram",
          "tokenFrom": { "env": "TELEGRAM_BOT_TOKEN" },
          "dmPolicy": "pairing"
        }
      ]
    }
  ],
  "postSetup": ["audit"]
}
