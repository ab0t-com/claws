{
  "apiVersion": "claws.ab0t.com/v1",
  "kind": "Profile",
  "metadata": {
    "name": "whatsapp-family",
    "version": "1.0.0",
    "description": "WhatsApp helper for a family/small group. Allowlist by phone number, no outbound, calendar + reminders + shopping-list skills. QR-scan auth.",
    "author": "ab0t",
    "license": "MIT",
    "tags": ["solo", "whatsapp", "family", "calendar", "reminders"]
  },
  "runtime": { "name": "openclaw", "image": "openclaw:local" },
  "policy": {
    "loopbackOnly": true,
    "dmDefault": "allowlist",
    "outboundDefault": "off"
  },
  "team": { "name": "default", "shared": true },
  "agents": [{
    "name": "family-helper",
    "sandbox": true,
    "tools": {
      "profile": "assistant",
      "allow": ["read", "edit", "memory", "calendar", "reminders"],
      "deny": ["bash", "exec", "web"]
    },
    "skills": [
      "calendar",
      "reminders",
      "shopping-list",
      "memory"
    ],
    "hooks": {
      "onStart": "echo \"family-helper booted\" >> $WORKSPACE/memory/boot.log",
      "onIdle":  "echo \"$(date -u +%FT%TZ) heartbeat\" >> $WORKSPACE/memory/heartbeat.log"
    },
    "config": {
      "agents.defaults.maxTokens": 4096,
      "memory.enabled": true,
      "memory.persistInterval": "1h"
    },
    "auth": {
      "preferred": "apikey",
      "fallbackApiKey": { "provider": "openai", "fromEnv": "OPENAI_API_KEY" }
    },
    "channels": [{
      "type": "whatsapp",
      "dmPolicy": "allowlist"
    }]
  }],
  "postSetup": ["audit"]
}
