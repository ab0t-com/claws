{
  "apiVersion": "claws.ab0t.com/v1",
  "kind": "Profile",
  "metadata": {
    "name": "personal-assistant",
    "version": "1.0.0",
    "description": "Always-on personal AI on Telegram with memory + skills + lifecycle hooks. Sarah-style: long-running session, daily heartbeat, structured workspace.",
    "author": "ab0t",
    "license": "MIT",
    "tags": ["solo", "telegram", "memory", "heartbeat", "assistant"]
  },
  "runtime": {
    "name": "openclaw",
    "image": "openclaw:local"
  },
  "policy": {
    "loopbackOnly": true,
    "dmDefault": "pairing",
    "outboundDefault": "off"
  },
  "team": {
    "name": "default",
    "shared": true
  },
  "agents": [
    {
      "name": "assistant",
      "sandbox": true,
      "tools": {
        "profile": "assistant",
        "allow": ["read", "edit", "bash", "web", "calendar", "memory"],
        "deny": ["network-raw"]
      },
      "skills": [
        "calendar",
        "memory",
        "web-search",
        "telegram-utils"
      ],
      "hooks": {
        "onStart": "echo \"[$(date -u +%FT%TZ)] assistant booted\" >> $WORKSPACE/memory/boot.log",
        "onIdle":  "echo \"[$(date -u +%FT%TZ)] heartbeat\"      >> $WORKSPACE/memory/heartbeat.log"
      },
      "config": {
        "agents.defaults.maxTokens": 8192,
        "agents.defaults.persona": "personal-assistant",
        "memory.enabled": true,
        "memory.persistInterval": "1h",
        "heartbeat.enabled": true,
        "heartbeat.intervalMinutes": 30
      },
      "auth": {
        "preferred": "codex",
        "fallbackApiKey": {
          "provider": "openai",
          "fromEnv": "OPENAI_API_KEY"
        }
      },
      "channels": [
        {
          "type": "telegram",
          "tokenFrom": { "env": "TELEGRAM_BOT_TOKEN" },
          "dmPolicy": "pairing"
        }
      ]
    }
  ],
  "postSetup": ["audit"]
}
